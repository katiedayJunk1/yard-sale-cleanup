# ==============================
# Backend environment variables
# ==============================

# Railway sets PORT automatically
NODE_ENV=production

# Timezone for the deal schedule
TIMEZONE=America/Chicago

# Deal settings (defaults for each new week)
DEFAULT_MIN_REQUIRED=10
DEFAULT_MAX_ALLOWED=20
DEAL_PRICE=50
FAIL_COUPON_CODE=JUNK10

# Postgres (Railway provides DATABASE_URL automatically when you add a Postgres plugin)
# DATABASE_URL=...

# CORS / Site URLs
# Your GitHub Pages site (used for CORS + links in emails)
FRONTEND_URL=https://YOUR_GITHUB_USERNAME.github.io/yard-sale-cleanup
PUBLIC_SITE_URL=https://YOUR_GITHUB_USERNAME.github.io/yard-sale-cleanup

# Admin API protection (pick a random string)
ADMIN_KEY=replace-with-a-long-random-string

# Email (Gmail + App Password)
EMAIL_SERVICE=gmail
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM=The Junkluggers <your_gmail@gmail.com>
